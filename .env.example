WIKINDIE_USER=dev:dev
JWT_SECRET=replace-with-a-long-random-string
SPACE_DIR=./space
PORT=3000
# Optional: set to true only if you want to seed the starter/demo workspace.
# WIKINDIE_INIT_DEFAULT_SPACE=true
# Optional: allow anonymous read-only browsing for public showcase deployments.
# WIKINDIE_PUBLIC_READONLY=true
# WIKINDIE_PUBLIC_DEFAULT_PAGE=Projects/Wikindie/Roadmap
# Optional: comma-separated hostnames allowed to serve this app, for example wiki.example.com.
# WIKINDIE_ALLOWED_HOSTS=wiki.example.com
# Optional: comma-separated origins allowed for cross-origin API calls.
# WIKINDIE_CORS_ORIGINS=https://wiki.example.com
# Optional: login rate limit tuning.
# WIKINDIE_LOGIN_RATE_LIMIT_MAX=10
# WIKINDIE_LOGIN_RATE_LIMIT_WINDOW_MS=900000
