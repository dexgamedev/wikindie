WIKINDIE_USER=dev:dev
JWT_SECRET=replace-with-a-long-random-string
SPACE_DIR=./space
PORT=3000
# Optional: set to true only if you want to seed the starter/demo workspace.
# WIKINDIE_INIT_DEFAULT_SPACE=true
# Optional: allow anonymous read-only browsing for public showcase deployments.
# WIKINDIE_PUBLIC_READONLY=true
# WIKINDIE_PUBLIC_DEFAULT_PAGE=Projects/Wikindie/Roadmap
# Optional: comma-separated hostnames allowed to serve this app, for example wiki.example.com.
# WIKINDIE_ALLOWED_HOSTS=wiki.example.com
# Optional: comma-separated origins allowed for cross-origin API calls.
# WIKINDIE_CORS_ORIGINS=https://wiki.example.com
# Optional: login rate limit tuning.
# WIKINDIE_LOGIN_RATE_LIMIT_MAX=10
# WIKINDIE_LOGIN_RATE_LIMIT_WINDOW_MS=900000
# Optional: password change rate limit tuning.
# WIKINDIE_PASSWORD_RATE_LIMIT_MAX=5
# WIKINDIE_PASSWORD_RATE_LIMIT_WINDOW_MS=900000
# Optional: maximum bytes accepted for one attachment upload. Default is 25 MB.
# WIKINDIE_ATTACHMENT_MAX_BYTES=26214400

# --- OIDC / SSO (optional, off by default) ---------------------------------
# Enable single sign-on via any OIDC provider (e.g. Authentik, Keycloak).
# Local username/password login keeps working alongside it.
# OIDC_ENABLED=true
# OIDC_ISSUER=https://authentik.example.com/application/o/wikindie/
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret   # omit for a public (PKCE-only) client
# Optional: exact redirect URI. Defaults to <request-origin>/api/auth/oidc/callback.
# Register this value as the redirect URI in your provider.
# OIDC_REDIRECT_URI=https://wiki.example.com/api/auth/oidc/callback
# Optional: space-separated scopes. Add "groups" if you use group→role mapping.
# OIDC_SCOPES=openid profile email
# Optional: which claim to use as the Wikindie username.
# OIDC_USERNAME_CLAIM=preferred_username
# Optional: role granted when no group mapping matches. Default: readonly.
# OIDC_DEFAULT_ROLE=editor
# Optional: map provider groups to roles (comma-separated, case-insensitive).
# Group mappings seed a user's role on first login (JIT provisioning).
# OIDC_GROUPS_CLAIM=groups
# OIDC_ADMIN_GROUPS=wiki-admins
# OIDC_EDITOR_GROUPS=wiki-editors
# OIDC_READONLY_GROUPS=wiki-viewers
# Optional: re-sync roles from the IdP on EVERY login (IdP is source of truth,
# overwrites roles changed in the UI). Default false: groups only seed the role
# on first login and manual UI changes persist afterwards.
# OIDC_SYNC_ROLES=true
# Optional: text on the SSO button. Default: "Sign in with SSO".
# OIDC_BUTTON_LABEL=Sign in with Authentik
# Optional: allow an http:// issuer (local testing only; never in production).
# OIDC_ALLOW_INSECURE=true
